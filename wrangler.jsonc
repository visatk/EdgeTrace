{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "edgetrace",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-02",
	"compatibility_flags": [
    "nodejs_compat"
  ],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 0.1
	},
	"upload_source_maps": true,
	"placement": {
		"mode": "smart"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "shop-cache",
			"database_id": "ca0563a4-8e2e-4fb9-b55d-f1a8e229490e"
		}
	]
}
